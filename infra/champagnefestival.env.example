# Champagne Festival — production environment variables
# Managed by the infra stack. Copy to champagnefestival.env and fill in values.

# ─── OIDC ─────────────────────────────────────────────────────────────────────

# OIDC provider base URL. Required.
# Example (authentik): https://auth.example.com/application/o/champagnefestival
OIDC_ISSUER_URL=

# Expected audience claim in the JWT. Optional.
OIDC_AUDIENCE=

# JWKS endpoint override. Leave empty to use {OIDC_ISSUER_URL}/.well-known/jwks.json.
OIDC_JWKS_URI=

# Comma-separated list of accepted JWT signing algorithms.
OIDC_ALGORITHMS=RS256

# Comma-separated list of usernames (preferred_username claim) allowed as admins. Required.
ADMIN_USERNAMES=

# ─── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins.  Must include the frontend domain.
CORS_ORIGINS=https://champagnefestival.tjor.im
