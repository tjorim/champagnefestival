# Champagne Festival — production environment variables
# Managed by the infra stack. Copy to champagnefestival.env and fill in values.

# ─── SuperTokens ──────────────────────────────────────────────────────────────

# Connection URI for the self-hosted SuperTokens core.
SUPERTOKENS_CONNECTION_URI=http://supertokens:3567

# API key to secure the SuperTokens core connection.
SUPERTOKENS_API_KEY=

# Public URL where the API is reachable.
API_DOMAIN=https://champagnefestival.tjor.im

# Public URL where the frontend is reachable.
WEBSITE_DOMAIN=https://champagnefestival.tjor.im

# Base path for SuperTokens API routes (e.g. /api/auth/signin, /api/auth/signout).
API_BASE_PATH=/api/auth

# Base path for SuperTokens frontend routes on the website domain.
WEBSITE_BASE_PATH=/admin

# ─── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins.  Must include the frontend domain.
CORS_ORIGINS=https://champagnefestival.tjor.im
