# Champagne Festival Backend — environment variables
# Copy this file to .env and fill in the values.
# Never commit the actual .env file to version control.

# ─── Environment ─────────────────────────────────────────────────────────────

# Deployment environment. Controls security validators and logging behaviour.
# Values: development | production
# In production the server will refuse to start if OIDC_ISSUER_URL or ADMIN_USERNAMES is empty.
ENVIRONMENT=development

# ─── OIDC ─────────────────────────────────────────────────────────────────────

# OIDC provider base URL.
# Required in production. Example: https://auth.example.com/application/o/champagnefestival
OIDC_ISSUER_URL=

# Expected audience claim in the JWT. Optional.
OIDC_AUDIENCE=

# JWKS endpoint override. Defaults to {OIDC_ISSUER_URL}/.well-known/jwks.json when empty.
OIDC_JWKS_URI=

# Comma-separated list of accepted JWT signing algorithms.
OIDC_ALGORITHMS=RS256

# Comma-separated list of usernames allowed to access admin endpoints.
# Matched against the preferred_username (or email local part) claim in the JWT.
# Required in production. Example: jorim,alice
ADMIN_USERNAMES=

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection URL.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/champagne
# Production (dedicated user — credentials managed in infra repo):
# DATABASE_URL=postgresql+asyncpg://champagnefestival_user:CHANGE_ME@postgres:5432/champagnefestival

# ─── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins.
# An empty value means no browser origins are allowed (safe production default).
# Wildcard '*' is permitted only outside production.
# For local development add http://localhost:5173 (Vite default).
# Example: CORS_ORIGINS=https://champagnefestival.be,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── Anti-spam ───────────────────────────────────────────────────────────────

# Minimum seconds between form load and submission (bot protection).
MIN_FORM_SECONDS=3

# ─── Metrics ─────────────────────────────────────────────────────────────────

# Shared secret required in the X-Metrics-Secret header to access GET /api/metrics.
# Leave empty to disable the metrics endpoint (403 Forbidden).
METRICS_SECRET=

# ─── Email notifications (planned — not yet implemented) ─────────────────────
# Once implemented, a confirmation e-mail with QR code will be sent to the
# guest on successful reservation creation.

SMTP_FROM=
SMTP_HOST=
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_USER=

# ─── reCAPTCHA (planned — not yet implemented) ───────────────────────────────
# Once implemented, the public reservation endpoint will verify a reCAPTCHA
# v2/v3 token submitted alongside the form.

RECAPTCHA_SECRET=
