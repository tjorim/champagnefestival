# Champagne Festival Backend — environment variables
# Copy this file to .env and fill in the values.
# Never commit the actual .env file to version control.

# ─── Environment ─────────────────────────────────────────────────────────────

# Deployment environment. Controls security validators and logging behaviour.
# Values: development | production
# In production the server will refuse to start if ADMIN_TOKEN is empty.
ENVIRONMENT=development

# ─── Required ───────────────────────────────────────────────────────────────

# Long random string used as the admin bearer token.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=

# ─── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection URL.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/champagne

# ─── CORS ────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins.
# An empty value means no browser origins are allowed (safe production default).
# Wildcard '*' is permitted only outside production.
# For local development add http://localhost:5173 (Vite default).
# Example: CORS_ORIGINS=https://champagnefestival.be,http://localhost:5173
CORS_ORIGINS=https://champagnefestival.be

# ─── Anti-spam ───────────────────────────────────────────────────────────────

# Minimum seconds between form load and submission (bot protection).
MIN_FORM_SECONDS=3

# ─── Email notifications (planned — not yet implemented) ─────────────────────
# Once implemented, a confirmation e-mail with QR code will be sent to the
# guest on successful reservation creation.

SMTP_FROM=
SMTP_HOST=
SMTP_PASSWORD=
SMTP_PORT=587
SMTP_USER=

# ─── reCAPTCHA (planned — not yet implemented) ───────────────────────────────
# Once implemented, the public reservation endpoint will verify a reCAPTCHA
# v2/v3 token submitted alongside the form.

RECAPTCHA_SECRET=
