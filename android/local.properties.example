# Copy this file to local.properties (already in .gitignore) and fill in the values.
# local.properties is never committed to version control.

# ---- Android SDK location (required by Android Gradle Plugin) ----
# sdk.dir=/Users/<you>/Library/Android/sdk

# API base URL (required when building a release artifact, e.g.
# :app:assembleRelease -- not just that one task).
# ANDROID_API_BASE_URL=https://champagnefestival.tjor.im/

# Optional override for debug builds. Defaults to the Android emulator loopback,
# http://10.0.2.2:8000/, which only resolves if you're running the backend locally
# (docker compose up db -d && cd backend && uv run uvicorn app.main:app --reload).
# If you don't run a local backend, point this at the real API instead -- note this
# also requires the debug OIDC redirect URI (im.tjor.champagnefestival.debug://oauth2redirect)
# to be registered with the OIDC provider serving that backend.
# ANDROID_DEBUG_API_BASE_URL=https://champagnefestival.tjor.im/

# Certificate pin host and pins (required when building a release artifact;
# debug never pins, regardless of these values).
# ANDROID_CERTIFICATE_PIN_HOST=champagnefestival.tjor.im
# ANDROID_CERTIFICATE_PINS=sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=,sha256/BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=
