{
  "name": "champagnefestival",
  "version": "0.1.0",
  "private": true,
  "description": "Champagne Festival website using React and Bootstrap",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm paraglide:compile && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm paraglide:compile && tsc -b --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/react": "^0.5.0",
    "@tanstack/query-db-collection": "^1.0.40",
    "@tanstack/react-db": "^0.1.86",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-table": "9.0.0-beta.16",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "leaflet": "^1.9.4",
    "oidc-client-ts": "^3.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-bootstrap": "^3.0.0-beta.5",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-leaflet": "^5.0.0",
    "react-oidc-context": "^3.2.0",
    "react-select": "^5.10.2",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.19.0",
    "@inlang/plugin-m-function-matcher": "^2.2.7",
    "@inlang/plugin-message-format": "^4.4.0",
    "@playwright/test": "^1.56.0",
    "@tanstack/table-core": "9.0.0-beta.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.8",
    "happy-dom": "^20.10.1",
    "jest-axe": "^10.0.0",
    "msw": "^2.14.6",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
