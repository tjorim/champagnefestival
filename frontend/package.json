{
  "name": "champagnefestival",
  "version": "0.1.0",
  "private": true,
  "description": "Champagne Festival website using React and Bootstrap",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm paraglide:compile && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm paraglide:compile && tsc -b --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.94.5",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.1",
    "react-bootstrap": "^3.0.0-beta.5",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.1.1",
    "react-leaflet": "^5.0.0",
    "@tanstack/react-router": "^1.168.3",
    "react-select": "^5.10.2",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.15.1",
    "@inlang/plugin-m-function-matcher": "^2.2.4",
    "@inlang/plugin-message-format": "^4.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.1",
    "happy-dom": "^20.8.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
