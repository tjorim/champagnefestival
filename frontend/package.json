{
  "name": "champagnefestival",
  "version": "0.1.0",
  "private": true,
  "description": "Champagne Festival website using React and Bootstrap",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm paraglide:compile && tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "pnpm paraglide:compile && tsc -b --noEmit",
    "lint": "oxlint",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations"
  },
  "dependencies": {
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/react": "^0.4.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-table": "9.0.0-alpha.41",
    "bootstrap": "^5.3.7",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "leaflet": "^1.9.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-bootstrap": "^3.0.0-beta.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-leaflet": "^5.0.0",
    "react-select": "^5.10.2",
    "supertokens-auth-react": "^0.51.2",
    "supertokens-web-js": "^0.16.0",
    "swiper": "^12.1.4"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.18.0",
    "@inlang/plugin-m-function-matcher": "^2.2.6",
    "@inlang/plugin-message-format": "^4.4.0",
    "@tanstack/table-core": "9.0.0-alpha.41",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
